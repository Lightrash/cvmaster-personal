PORT=5000
JWT_SECRET=dev_jwt_secret
# For persistent local DB (installed MongoDB):
# MONGO_URI=mongodb://127.0.0.1:27017/cvmaster
# Leave empty to use auto in-memory MongoDB for development.
MONGO_URI=
GEMINI_API_KEY=your_gemini_api_key_here
# true = local stub for AI endpoints without Gemini key
AI_MOCK=false
# true = if Gemini quota/rate limit hits, backend returns mock AI result instead of error
AI_FALLBACK_ON_QUOTA=false
TRASH_RETENTION_DAYS=7
TRASH_CLEANUP_INTERVAL_MINUTES=60
